### Backend environment (local development)
### Copy to backend/.env and fill values.

# --- OpenAI ---
OPENAI_API_KEY=

# --- App ---
CONTAINER_PREFIX=docgen

# --- Database ---
# Prefer DATABASE_URL when available.
DATABASE_URL=
DB_USER=postgres
DB_PASSWORD=mysecretpassword
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_ECHO=false

# --- Storage (S3 / Dummy S3) ---
S3_BUCKET_NAME=
S3_ENDPOINT_URL=http://localhost:9002
AWS_DEFAULT_REGION=eu-west-2

# Optional for local dev with static keys (App Runner should use an IAM role)
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# --- Feature flags / mocks ---
USE_MOCK_LLM=false
USE_MOCK_STORAGE=false
